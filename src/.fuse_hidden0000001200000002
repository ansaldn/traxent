<style>
:root {
  --bg: #f7f6f2;
  --ink: #0e0e0c;
  --ink2: #3a3a36;
  --ink3: #7a7a72;
  --accent: #0a6e4f;
  --accent-light: rgba(10,110,79,.08);
  --border: rgba(14,14,12,0.1);
  --border2: rgba(14,14,12,0.06);
  --surface: #ffffff;
  --surface2: #f0efe9;
  --good: #0a6e4f;
  --warn: #b06000;
  --bad: #9e1a1a;
  --serif: 'Instrument Serif', Georgia, serif;
  --sans: 'Geist', sans-serif;
  --mono: 'Geist Mono', monospace;
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { font-size: 16px; scroll-behavior: smooth; }
body { background: var(--bg); color: var(--ink); font-family: var(--sans); min-height: 100vh; -webkit-font-smoothing: antialiased; }

nav { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 40px; height: 60px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
.nav-logo { font-family: var(--mono); font-size: 15px; color: var(--ink); text-decoration: none; }
.nav-logo em { font-style: normal; color: var(--accent); }
.nav-links { display: flex; align-items: center; gap: 20px; }
.nav-links a { font-size: 13px; color: var(--ink3); text-decoration: none; transition: color 0.15s; }
.nav-links a:hover { color: var(--ink); }
.nav-cta { background: var(--ink); color: white !important; padding: 8px 16px; border-radius: 6px; font-size: 13px !important; transition: background 0.15s !important; }
.nav-cta:hover { background: var(--accent) !important; }

.main { max-width: 1000px; margin: 0 auto; padding: 56px 40px 96px; }

/* Header */
.page-header { margin-bottom: 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: end; }
.page-eyebrow { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; display: flex; align-items: center; gap: 10px; }
.page-eyebrow::before { content: ''; width: 20px; height: 1px; background: var(--accent); }
.page-title { font-family: var(--serif); font-size: 44px; font-weight: 400; color: var(--ink); margin-bottom: 12px; line-height: 1.1; }
.page-sub { font-size: 15px; color: var(--ink3); line-height: 1.65; font-weight: 300; }
.header-formula { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 24px; }
.formula-label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); margin-bottom: 14px; }
.formula-line { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; font-size: 13px; }
.formula-line:last-child { margin-bottom: 0; }
.formula-var { font-family: var(--mono); font-size: 12px; background: var(--accent-light); color: var(--accent); padding: 3px 8px; border-radius: 4px; border: 1px solid rgba(10,110,79,.15); }
.formula-op { color: var(--ink3); font-size: 14px; }
.formula-desc { font-size: 12px; color: var(--ink3); }

/* Calculator layout */
.calc-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; align-items: start; }

/* Input card */
.calc-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }
.calc-card-header { padding: 16px 22px; border-bottom: 1px solid var(--border2); display: flex; align-items: center; justify-content: space-between; }
.calc-card-title { font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); }
.calc-card-badge { font-family: var(--mono); font-size: 10px; color: var(--accent); background: var(--accent-light); border: 1px solid rgba(10,110,79,.15); padding: 3px 8px; border-radius: 3px; letter-spacing: 0.06em; }

/* Input groups */
.input-group { padding: 16px 22px; border-bottom: 1px solid var(--border2); }
.input-group:last-of-type { border-bottom: none; }
.input-label { font-size: 13px; font-weight: 500; color: var(--ink); margin-bottom: 4px; }
.input-hint { font-size: 11px; color: var(--ink3); margin-bottom: 10px; line-height: 1.4; }
.input-row { display: flex; gap: 0; }
.input-field { flex: 1; background: var(--bg); border: 1px solid var(--border); border-radius: 6px 0 0 6px; padding: 10px 14px; font-family: var(--sans); font-size: 14px; color: var(--ink); outline: none; transition: border-color 0.15s, box-shadow 0.15s; }
.input-field:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(10,110,79,.07); }
.input-field.no-unit { border-radius: 6px; }
.input-unit { background: var(--surface2); border: 1px solid var(--border); border-left: none; border-radius: 0 6px 6px 0; padding: 10px 12px; font-size: 12px; color: var(--ink3); font-family: var(--mono); display: flex; align-items: center; white-space: nowrap; }
.input-toggle { display: flex; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
.toggle-opt { flex: 1; padding: 9px 0; font-size: 12px; font-family: var(--mono); color: var(--ink3); background: none; border: none; cursor: pointer; transition: all 0.15s; text-align: center; }
.toggle-opt.active { background: var(--accent); color: white; }
.risk-presets { display: flex; gap: 6px; margin-top: 8px; }
.risk-preset { background: none; border: 1px solid var(--border); border-radius: 5px; padding: 5px 10px; font-size: 11px; font-family: var(--mono); color: var(--ink3); cursor: pointer; transition: all 0.15s; }
.risk-preset:hover { border-color: var(--accent); color: var(--accent); }
.risk-preset.active { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }

/* Results card */
.results-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; position: sticky; top: 76px; }
.results-placeholder { padding: 48px 24px; text-align: center; }
.results-placeholder-icon { font-size: 32px; margin-bottom: 12px; opacity: 0.4; }
.results-placeholder-text { font-size: 14px; color: var(--ink3); font-weight: 300; }

/* Main result */
.main-result { padding: 24px; border-bottom: 1px solid var(--border2); }
.main-result-label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); margin-bottom: 10px; }
.main-result-value { font-family: var(--serif); font-size: 56px; font-weight: 400; font-style: italic; color: var(--ink); line-height: 1; margin-bottom: 4px; }
.main-result-sub { font-size: 13px; color: var(--ink3); }

/* Result rows */
.result-row { display: flex; align-items: center; justify-content: space-between; padding: 13px 22px; border-bottom: 1px solid var(--border2); }
.result-row:last-child { border-bottom: none; }
.result-row-label { font-size: 13px; color: var(--ink3); }
.result-row-value { font-family: var(--mono); font-size: 13px; color: var(--ink); font-weight: 500; }
.result-row-value.green { color: var(--good); }
.result-row-value.amber { color: var(--warn); }
.result-row-value.red { color: var(--bad); }

/* Step by step working */
.working-section { padding: 18px 22px; border-top: 1px solid var(--border2); background: var(--surface2); }
.working-title { font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); margin-bottom: 12px; }
.working-step { display: flex; gap: 10px; margin-bottom: 8px; font-size: 12px; line-height: 1.5; }
.working-step:last-child { margin-bottom: 0; }
.working-num { font-family: var(--mono); color: var(--accent); font-size: 11px; flex-shrink: 0; margin-top: 1px; }
.working-text { color: var(--ink2); }
.working-text strong { color: var(--ink); font-weight: 500; }

/* Warning / info boxes */
.result-warning { margin: 0 22px 16px; padding: 12px 14px; background: rgba(158,26,26,.06); border: 1px solid rgba(158,26,26,.15); border-radius: 6px; font-size: 12px; color: var(--bad); line-height: 1.5; display: none; }
.result-info { margin: 0 22px 16px; padding: 12px 14px; background: var(--accent-light); border: 1px solid rgba(10,110,79,.15); border-radius: 6px; font-size: 12px; color: var(--accent); line-height: 1.5; display: none; }

/* Prop firm context */
.prop-context { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 28px; margin-top: 28px; }
.prop-context-title { font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); margin-bottom: 20px; }
.prop-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
.prop-cell { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; padding: 14px; }
.prop-cell-name { font-size: 12px; font-weight: 500; color: var(--ink); margin-bottom: 6px; }
.prop-cell-rule { font-size: 11px; color: var(--ink3); margin-bottom: 4px; font-family: var(--mono); }
.prop-cell-status { font-size: 11px; font-weight: 500; margin-top: 8px; padding: 3px 0; }
.prop-cell-status.pass { color: var(--good); }
.prop-cell-status.warn { color: var(--warn); }
.prop-cell-status.fail { color: var(--bad); }

/* CTA */
.tracker-cta { background: var(--ink); border-radius: 14px; padding: 32px 36px; margin-top: 28px; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
.tracker-cta-left { display: flex; flex-direction: column; gap: 6px; }
.tracker-cta-title { font-family: var(--serif); font-size: 22px; color: white; font-weight: 400; }
.tracker-cta-sub { font-size: 13px; color: rgba(255,255,255,.45); font-weight: 300; }
.tracker-cta-btn { background: #1a9e72; color: white; padding: 11px 22px; border-radius: 8px; font-size: 13px; font-weight: 500; text-decoration: none; white-space: nowrap; transition: background 0.15s; }
.tracker-cta-btn:hover { background: var(--accent); }

/* Disclaimer */
.disclaimer { font-size: 11px; color: var(--ink3); line-height: 1.6; padding: 20px 0; border-top: 1px solid var(--border); margin-top: 28px; }

footer { background: var(--ink); padding: 40px; }
.footer-inner { max-width: 1000px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
.footer-logo { font-family: var(--mono); font-size: 15px; color: white; }
.footer-logo em { font-style: normal; color: #1a9e72; }
.footer-links { display: flex; gap: 24px; }
.footer-links a { font-size: 12px; color: rgba(255,255,255,.4); text-decoration: none; transition: color 0.15s; }
.footer-links a:hover { color: white; }

@media (max-width: 768px) {
  .main { padding: 36px 20px 64px; }
  nav { padding: 0 20px; }
  .page-header { grid-template-columns: 1fr; gap: 24px; }
  .calc-layout { grid-template-columns: 1fr; }
  .results-card { position: static; }
  .prop-grid { grid-template-columns: repeat(2, 1fr); }
  .tracker-cta { flex-direction: column; align-items: flex-start; padding: 24px; }
  .nav-links { display: none; }
}
</style>
</head>
