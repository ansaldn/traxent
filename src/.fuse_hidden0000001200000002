<div class="main">

  <div class="page-header">
    <div>
      <div class="page-eyebrow">Free tool</div>
      <h1 class="page-title">Position size calculator</h1>
      <p class="page-sub">Enter your account size, risk percentage, and stop loss distance. We'll tell you exactly how many units to trade so your loss never exceeds your plan.</p>
    </div>
    <div class="header-formula">
      <div class="formula-label">The formula</div>
      <div class="formula-line">
        <span class="formula-var">Risk £</span>
        <span class="formula-op">=</span>
        <span class="formula-desc">Account size × Risk %</span>
      </div>
      <div class="formula-line">
        <span class="formula-var">Stop distance</span>
        <span class="formula-op">=</span>
        <span class="formula-desc">Entry price − Stop loss price</span>
      </div>
      <div class="formula-line">
        <span class="formula-var">Position size</span>
        <span class="formula-op">=</span>
        <span class="formula-desc">Risk £ ÷ Stop distance</span>
      </div>
    </div>
  </div>

  <div class="calc-layout">

    <!-- Inputs -->
    <div class="calc-card">
      <div class="calc-card-header">
        <span class="calc-card-title">Your inputs</span>
        <span class="calc-card-badge">FREE · No login required</span>
      </div>

      <div class="input-group">
        <div class="input-label">Account size</div>
        <div class="input-hint">Your total trading account balance</div>
        <div class="input-row">
          <input type="number" class="input-field" id="account-size" value="10000" min="0" oninput="calculate()" placeholder="10000">
          <div class="input-unit" id="currency-symbol">£</div>
        </div>
      </div>

      <div class="input-group">
        <div class="input-label">Currency</div>
        <div class="input-hint">Account denomination</div>
        <div class="input-toggle">
          <button class="toggle-opt active" onclick="setCurrency('GBP', this)">£ GBP</button>
          <button class="toggle-opt" onclick="setCurrency('USD', this)">$ USD</button>
          <button class="toggle-opt" onclick="setCurrency('EUR', this)">€ EUR</button>
        </div>
      </div>

      <div class="input-group">
        <div class="input-label">Risk per trade</div>
        <div class="input-hint">What % of your account are you willing to lose on this trade?</div>
        <div class="input-row">
          <input type="number" class="input-field" id="risk-pct" value="1" min="0.1" max="10" step="0.1" oninput="calculate(); updatePresets()">
          <div class="input-unit">%</div>
        </div>
        <div class="risk-presets">
          <button class="risk-preset active" onclick="setRisk(0.5)">0.5%</button>
          <button class="risk-preset" onclick="setRisk(1)">1%</button>
          <button class="risk-preset" onclick="setRisk(1.5)">1.5%</button>
          <button class="risk-preset" onclick="setRisk(2)">2%</button>
        </div>
      </div>

      <div class="input-group">
        <div class="input-label">Entry price</div>
        <div class="input-hint">The price you plan to enter the trade at</div>
        <div class="input-row">
          <input type="number" class="input-field no-unit" id="entry-price" value="" min="0" step="any" oninput="calculate()" placeholder="e.g. 5200.00">
        </div>
      </div>

      <div class="input-group">
        <div class="input-label">Stop loss price</div>
        <div class="input-hint">The price at which you'll exit if the trade goes against you</div>
        <div class="input-row">
          <input type="number" class="input-field no-unit" id="stop-price" value="" min="0" step="any" oninput="calculate()" placeholder="e.g. 5190.00">
        </div>
      </div>

      <div class="input-group">
        <div class="input-label">Profit target <span style="color:var(--ink3);font-weight:300;font-size:11px">(optional)</span></div>
        <div class="input-hint">Enter to calculate your risk to reward ratio</div>
        <div class="input-row">
          <input type="number" class="input-field no-unit" id="target-price" value="" min="0" step="any" oninput="calculate()" placeholder="e.g. 5230.00">
        </div>
      </div>

      <div class="input-group">
        <div class="input-label">Trade direction</div>
        <div class="input-hint">Are you buying or selling?</div>
        <div class="input-toggle">
          <button class="toggle-opt active" id="dir-long" onclick="setDirection('long', this)">▲ Long (buy)</button>
          <button class="toggle-opt" id="dir-short" onclick="setDirection('short', this)">▼ Short (sell)</button>
        </div>
      </div>

    </div>

    <!-- Results -->
    <div class="results-card" id="results-card">
      <div class="calc-card-header">
        <span class="calc-card-title">Your position</span>
      </div>

      <div id="results-placeholder" class="results-placeholder">
        <div class="results-placeholder-icon">🧮</div>
        <div class="results-placeholder-text">Enter your entry and stop loss prices to see your position size</div>
      </div>

      <div id="results-content" style="display:none">
        <div class="main-result">
          <div class="main-result-label">Position size</div>
          <div class="main-result-value" id="result-size">—</div>
          <div class="main-result-sub" id="result-size-sub">units / contracts</div>
        </div>

        <div class="result-warning" id="result-warning"></div>
        <div class="result-info" id="result-info"></div>

        <div class="result-row">
          <span class="result-row-label">Maximum loss</span>
          <span class="result-row-value" id="result-max-loss">—</span>
        </div>
        <div class="result-row">
          <span class="result-row-label">Risk percentage</span>
          <span class="result-row-value" id="result-risk-pct">—</span>
        </div>
        <div class="result-row">
          <span class="result-row-label">Stop distance</span>
          <span class="result-row-value" id="result-stop-dist">—</span>
        </div>
        <div class="result-row" id="rr-row" style="display:none">
          <span class="result-row-label">Risk to reward</span>
          <span class="result-row-value" id="result-rr">—</span>
        </div>
        <div class="result-row" id="profit-row" style="display:none">
          <span class="result-row-label">Potential profit</span>
          <span class="result-row-value green" id="result-profit">—</span>
        </div>

        <div class="working-section">
          <div class="working-title">Step-by-step working</div>
          <div id="working-steps"></div>
        </div>
      </div>
    </div>

  </div>

  <!-- Prop firm context -->
