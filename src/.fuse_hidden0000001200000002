    <div class="prop-context-title">How this trade sits against prop firm daily limits</div>
    <div class="prop-grid" id="prop-grid"></div>
  </div>

  <!-- Tracker CTA -->
  <div class="tracker-cta">
    <div class="tracker-cta-left">
      <div class="tracker-cta-title">Track every trade against prop firm rules</div>
      <div class="tracker-cta-sub">The readiness tracker scores your habits against FTMO, Apex, MFFU and FundedNext in real time. Available on the Challenger plan.</div>
    </div>
    <a href="/tracker" class="tracker-cta-btn">Open readiness tracker →</a>
  </div>

  <div class="disclaimer">
