<script>
let currency = 'GBP';
let direction = 'long';
const symbols = { GBP: '£', USD: '$', EUR: '€' };

const PROP_FIRMS = [
  { name: 'FTMO', dailyLimit: 5, totalLimit: 10 },
  { name: 'Apex', dailyLimit: null, totalLimit: 5 },
  { name: 'MFFU', dailyLimit: null, totalLimit: 3 },
  { name: 'FundedNext', dailyLimit: 5, totalLimit: 10 },
];

function setCurrency(c, btn) {
  currency = c;
  document.querySelectorAll('.toggle-opt').forEach(b => {
    if (b.textContent.includes('GBP') || b.textContent.includes('USD') || b.textContent.includes('EUR')) {
      b.classList.remove('active');
    }
  });
  btn.classList.add('active');
  document.getElementById('currency-symbol').textContent = symbols[c];
  calculate();
  localStorage.setItem('traxent_calc_currency', c);
}

function setDirection(dir, btn) {
  direction = dir;
  document.getElementById('dir-long').classList.toggle('active', dir === 'long');
  document.getElementById('dir-short').classList.toggle('active', dir === 'short');
  calculate();
}

function setRisk(val) {
  document.getElementById('risk-pct').value = val;
  updatePresets();
  calculate();
}

function updatePresets() {
  const val = parseFloat(document.getElementById('risk-pct').value);
  document.querySelectorAll('.risk-preset').forEach(btn => {
    btn.classList.toggle('active', parseFloat(btn.textContent) === val);
  });
}

function fmt(val, decimals = 2) {
  return val.toLocaleString('en-GB', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
}

function calculate() {
  const accountSize = parseFloat(document.getElementById('account-size').value) || 0;
  const riskPct = parseFloat(document.getElementById('risk-pct').value) || 0;
  const entryPrice = parseFloat(document.getElementById('entry-price').value) || 0;
  const stopPrice = parseFloat(document.getElementById('stop-price').value) || 0;
  const targetPrice = parseFloat(document.getElementById('target-price').value) || 0;
  const sym = symbols[currency];

  // Save account size
  if (accountSize > 0) localStorage.setItem('traxent_account_size', accountSize);
  if (currency) localStorage.setItem('traxent_calc_currency', currency);

  // Need entry and stop to calculate
  if (!entryPrice || !stopPrice) {
    document.getElementById('results-placeholder').style.display = 'block';
    document.getElementById('results-content').style.display = 'none';
    document.getElementById('prop-context').style.display = 'none';
    return;
  }

  const stopDistance = Math.abs(entryPrice - stopPrice);

  // Validate direction
  const isLong = direction === 'long';
  const directionValid = isLong ? stopPrice < entryPrice : stopPrice > entryPrice;

  const riskAmount = accountSize * (riskPct / 100);
  const positionSize = stopDistance > 0 ? riskAmount / stopDistance : 0;

  // Risk to reward
  let rrRatio = null;
  let profitAmount = null;
  if (targetPrice > 0) {
    const targetDistance = Math.abs(targetPrice - entryPrice);
    rrRatio = targetDistance / stopDistance;
    profitAmount = positionSize * targetDistance;
  }

  // Show results
  document.getElementById('results-placeholder').style.display = 'none';
  document.getElementById('results-content').style.display = 'block';

  document.getElementById('result-size').textContent = fmt(positionSize, positionSize < 1 ? 4 : 2);
  document.getElementById('result-size-sub').textContent = `units at ${sym}${fmt(entryPrice)} entry · ${sym}${fmt(riskAmount)} max loss`;
  document.getElementById('result-max-loss').textContent = `${sym}${fmt(riskAmount)}`;
  document.getElementById('result-max-loss').className = `result-row-value ${riskPct > 2 ? 'red' : riskPct > 1 ? 'amber' : 'green'}`;
  document.getElementById('result-risk-pct').textContent = `${riskPct}% of account`;
  document.getElementById('result-risk-pct').className = `result-row-value ${riskPct > 2 ? 'red' : riskPct > 1 ? 'amber' : 'green'}`;
  document.getElementById('result-stop-dist').textContent = `${fmt(stopDistance)} points / pips`;

  // R:R
  if (rrRatio !== null) {
    document.getElementById('rr-row').style.display = 'flex';
    document.getElementById('profit-row').style.display = 'flex';
    document.getElementById('result-rr').textContent = `1 : ${fmt(rrRatio, 2)}`;
    document.getElementById('result-rr').className = `result-row-value ${rrRatio >= 2 ? 'green' : rrRatio >= 1 ? 'amber' : 'red'}`;
    document.getElementById('result-profit').textContent = `${sym}${fmt(profitAmount)}`;
  } else {
    document.getElementById('rr-row').style.display = 'none';
    document.getElementById('profit-row').style.display = 'none';
  }

  // Warnings
  const warning = document.getElementById('result-warning');
  const info = document.getElementById('result-info');
  warning.style.display = 'none';
  info.style.display = 'none';

  if (!directionValid) {
    warning.textContent = `Your stop loss is on the wrong side of your entry for a ${direction} trade. For a ${isLong ? 'long' : 'short'}, the stop should be ${isLong ? 'below' : 'above'} the entry price.`;
    warning.style.display = 'block';
  } else if (riskPct > 3) {
    warning.textContent = `Risking ${riskPct}% per trade is high. Most prop firms allow a 5% daily loss limit — two trades at this risk on a bad day could breach that limit.`;
    warning.style.display = 'block';
  } else if (riskPct <= 1 && rrRatio !== null && rrRatio >= 2) {
    info.textContent = `Good setup — risking ${riskPct}% with a ${fmt(rrRatio, 1)}:1 R:R means you only need to win ${Math.ceil(100 / (rrRatio + 1))}% of trades to be profitable.`;
    info.style.display = 'block';
  }

  // Step by step working
  const steps = [
    `<strong>Risk amount:</strong> ${sym}${fmt(accountSize)} × ${riskPct}% = <strong>${sym}${fmt(riskAmount)}</strong>`,
    `<strong>Stop distance:</strong> |${fmt(entryPrice)} − ${fmt(stopPrice)}| = <strong>${fmt(stopDistance)} points</strong>`,
    `<strong>Position size:</strong> ${sym}${fmt(riskAmount)} ÷ ${fmt(stopDistance)} = <strong>${fmt(positionSize, positionSize < 1 ? 4 : 2)} units</strong>`,
  ];
  if (rrRatio !== null) {
    steps.push(`<strong>R:R ratio:</strong> ${fmt(Math.abs(targetPrice - entryPrice))} ÷ ${fmt(stopDistance)} = <strong>1:${fmt(rrRatio, 2)}</strong>`);
  }
  document.getElementById('working-steps').innerHTML = steps.map((s, i) =>
    `<div class="working-step"><span class="working-num">${i + 1}.</span><span class="working-text">${s}</span></div>`
  ).join('');

  // Prop firm context
  if (accountSize > 0 && riskAmount > 0) {
    document.getElementById('prop-context').style.display = 'block';
    const grid = document.getElementById('prop-grid');
    grid.innerHTML = PROP_FIRMS.map(f => {
      const dailyLimitAmt = f.dailyLimit ? accountSize * (f.dailyLimit / 100) : null;
      const tradesBeforeLimit = dailyLimitAmt ? Math.floor(dailyLimitAmt / riskAmount) : null;
      const riskPctOfDaily = dailyLimitAmt ? (riskAmount / dailyLimitAmt) * 100 : null;

      let status, statusText;
      if (!dailyLimitAmt) {
        status = 'pass';
        statusText = `No daily limit — trailing DD applies`;
      } else if (riskPctOfDaily <= 40) {
        status = 'pass';
        statusText = `${tradesBeforeLimit} losing trades before daily limit`;
      } else if (riskPctOfDaily <= 70) {
        status = 'warn';
        statusText = `Only ${tradesBeforeLimit} losing trades before limit`;
      } else {
        status = 'fail';
        statusText = `Too close to daily limit — reduce risk`;
      }

      return `
        <div class="prop-cell">
          <div class="prop-cell-name">${f.name}</div>
          <div class="prop-cell-rule">${f.dailyLimit ? `${f.dailyLimit}% daily limit = ${sym}${fmt(accountSize * f.dailyLimit / 100)}` : `No daily limit`}</div>
          <div class="prop-cell-rule">Max DD: ${f.totalLimit}%</div>
          <div class="prop-cell-status ${status}">${statusText}</div>
        </div>
      `;
    }).join('');
  }
}

// Load saved values
window.addEventListener('load', () => {
  const savedSize = localStorage.getItem('traxent_account_size');
  const savedCurrency = localStorage.getItem('traxent_calc_currency');
  if (savedSize) document.getElementById('account-size').value = savedSize;
  if (savedCurrency) {
    currency = savedCurrency;
    document.getElementById('currency-symbol').textContent = symbols[savedCurrency];
    document.querySelectorAll('.toggle-opt').forEach(btn => {
      if (btn.textContent.includes(savedCurrency)) btn.classList.add('active');
      else if ([' GBP', ' USD', ' EUR'].some(c => btn.textContent.includes(c.trim()))) btn.classList.remove('active');
    });
  }
  calculate();
});
</script>
